# Copy to .env.local (local stack) or .env.production (a real project).
# Local values come from `supabase status`.

# Postgres connection string (bulk seed + bench connect here).
# Local:  postgresql://postgres:postgres@127.0.0.1:55422/postgres
# Remote: use the "Session pooler" or "Direct connection" URI from the
#         project's Connect dialog, with your DB password filled in.
DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Needed only by the seed script (create bucket + upload spec files).
# Modern secret key (sb_secret_…); replaces the legacy service_role key.
SUPABASE_SECRET_KEY=

CAR_DETAILS_BUCKET=car-details
