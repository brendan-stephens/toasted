# Copy to .env.local (local stack) or .env.production (a real project).
# Local values come from `supabase status`.

# Postgres connection string (app, bulk seed + bench connect here).
# Local:  postgresql://postgres:postgres@127.0.0.1:55422/postgres
# Remote: use the "Session pooler" URI from the project's Connect dialog
#         (postgres.<ref>@aws-N-<region>.pooler.supabase.com:5432) with your
#         password. Prefer the pooler over "Direct connection" — the direct
#         db.<ref>.supabase.co host is IPv6-only and fails to resolve on many
#         IPv4 networks (getaddrinfo ENOTFOUND).
DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Needed only by the seed script (create bucket + upload spec files).
# Modern secret key (sb_secret_…); replaces the legacy service_role key.
SUPABASE_SECRET_KEY=

CAR_DETAILS_BUCKET=car-details
